{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post-Launch Learning Loop",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "launched_artifact",
    "success_metric_readout",
    "guardrail_metric_readout",
    "customer_signal",
    "assumption_updates",
    "decision",
    "next_discovery_inputs",
    "follow_up_actions"
  ],
  "properties": {
    "launched_artifact": {"type": "string"},
    "success_metric_readout": {"type": "array", "items": {"type": "string"}},
    "guardrail_metric_readout": {"type": "array", "items": {"type": "string"}},
    "customer_signal": {"type": "array", "items": {"type": "string"}},
    "assumption_updates": {"type": "array", "items": {"type": "string"}},
    "decision": {
      "type": "string",
      "enum": ["iterate", "monitor", "scale", "rollback_or_pause", "return_to_discovery", "stop"]
    },
    "next_discovery_inputs": {"type": "array", "items": {"type": "string"}},
    "follow_up_actions": {"type": "array", "items": {"type": "string"}}
  }
}
