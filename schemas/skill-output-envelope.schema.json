{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://product-operating-system.local/schemas/skill-output-envelope.schema.json",
  "title": "Skill Output Envelope",
  "type": "object",
  "required": ["artifact_type", "summary", "evidence", "assumptions", "recommendations", "next_actions"],
  "properties": {
    "artifact_type": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "source", "confidence"],
        "properties": {
          "claim": {"type": "string"},
          "source": {"type": "string"},
          "confidence": {"type": "string", "enum": ["low", "medium", "high"]}
        },
        "additionalProperties": false
      }
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "recommendations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_actions": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
