{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://product-operating-system.local/schemas/notion-page.schema.json",
  "title": "Notion Page Payload",
  "type": "object",
  "required": ["mode", "target", "title", "blocks", "confirmation_required"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["dry_run", "confirmed_write"]
    },
    "target": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {"type": "string", "enum": ["workspace", "database", "page"]},
        "id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "properties": {
      "type": "object"
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "content"],
        "properties": {
          "type": {"type": "string"},
          "content": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "source_artifact": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "dry_run_payload_hash": {
      "type": "string",
      "minLength": 1
    },
    "confirmation_required": {
      "type": "boolean"
    },
    "confirmation_evidence": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"mode": {"const": "dry_run"}},
        "required": ["mode"]
      },
      "then": {
        "required": ["idempotency_key", "dry_run_payload_hash"],
        "properties": {"confirmation_required": {"const": true}}
      }
    },
    {
      "if": {
        "properties": {"mode": {"const": "confirmed_write"}},
        "required": ["mode"]
      },
      "then": {
        "required": ["idempotency_key", "confirmation_evidence", "dry_run_payload_hash"],
        "properties": {"confirmation_required": {"const": false}}
      }
    }
  ],
  "additionalProperties": false
}
