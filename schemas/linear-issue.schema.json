{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://product-operating-system.local/schemas/linear-issue.schema.json",
  "title": "Linear Issue Payload",
  "type": "object",
  "required": ["mode", "team_key", "title", "description", "issue_type", "acceptance_criteria", "confirmation_required"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["dry_run", "confirmed_write"]
    },
    "team_key": {
      "type": "string",
      "minLength": 1
    },
    "team_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "issue_type": {
      "type": "string",
      "enum": ["epic", "story", "task", "bug", "chore"]
    },
    "priority": {
      "type": "string",
      "enum": ["no_priority", "low", "medium", "high", "urgent"]
    },
    "labels": {
      "type": "array",
      "items": {"type": "string"}
    },
    "label_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "state_id": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {"type": "string"}
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"}
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "dry_run_payload_hash": {
      "type": "string",
      "minLength": 1
    },
    "confirmation_required": {
      "type": "boolean"
    },
    "confirmation_evidence": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"mode": {"const": "dry_run"}},
        "required": ["mode"]
      },
      "then": {
        "required": ["idempotency_key", "dry_run_payload_hash"],
        "properties": {"confirmation_required": {"const": true}}
      }
    },
    {
      "if": {
        "properties": {"issue_type": {"enum": ["story", "task", "bug", "chore"]}},
        "required": ["issue_type"]
      },
      "then": {
        "properties": {"acceptance_criteria": {"minItems": 1}}
      }
    },
    {
      "if": {
        "properties": {"mode": {"const": "confirmed_write"}},
        "required": ["mode"]
      },
      "then": {
        "required": ["team_id", "idempotency_key", "confirmation_evidence", "dry_run_payload_hash"],
        "properties": {"confirmation_required": {"const": false}}
      }
    }
  ],
  "additionalProperties": false
}
